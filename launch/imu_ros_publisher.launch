<launch>
  <node pkg="imu_driver_ros" type="imu_ros_publisher" name="imu_ros_publisher" output="screen">

  <!-- 串口设备与波特率 -->
  <param name="port" value="/dev/ttyACM0"/>
  <param name="baud" type="int" value="460800"/>

  <!-- 串口读取超时（毫秒），0 表示阻塞 -->
  <param name="timeout_ms" type="int" value="10"/>

  <!-- 是否发布自定义 ImuData 消息（默认 true） -->
  <param name="publish_custom" type="bool" value="false"/>

  <!-- 是否发布 sensor_msgs/Imu 与 sensor_msgs/MagneticField（默认 false） -->
  <param name="publish_sensor_msgs" type="bool" value="true"/>

  <!-- 坐标系 ID -->
  <param name="frame_id" value="imu_link"/>

  <!-- ==================== 姿态解算参数 ==================== -->

  <!-- 是否启用姿态解算（默认 true） -->
  <param name="enable_attitude_estimation" type="bool" value="true"/>

  <!-- 算法类型：madgwick（梯度下降）或 mahony（互补滤波） -->
  <param name="algorithm_type" value="madgwick"/>

  <!-- 轴数模式：6（6轴：加速度计+陀螺仪）或 9（9轴：加速度计+陀螺仪+磁力计） -->
  <param name="axis_mode" value="6"/>

  <!-- Mahony 滤波器参数 -->
  <param name="kp" type="double" value="5.0"/>   <!-- 比例增益（越大跟踪越快，但噪声越大） -->
  <param name="ki" type="double" value="0.05"/>  <!-- 积分增益（消除稳态零偏漂移） -->

  <!-- Madgwick 滤波器参数 -->
  <param name="beta" type="double" value="0.3"/> <!-- 梯度下降步长 (rad/s) -->
  <param name="zeta" type="double" value="0.0"/> <!-- 陀螺仪零偏补偿系数 -->

  </node>
</launch>
